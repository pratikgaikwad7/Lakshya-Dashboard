# Flask session signing key. Use a long random value outside development.
SECRET_KEY=replace-with-a-long-random-secret
APP_ENV=development
SESSION_COOKIE_SECURE=false
SESSION_HOURS=8
MAX_CONTENT_LENGTH=10485760
LOG_LEVEL=INFO
RATELIMIT_STORAGE_URI=memory://

# Existing MySQL database used by the application.
DB_HOST=127.0.0.1
DB_USER=lakshya_app
DB_PASSWORD=replace-with-database-password
DB_NAME=lakshya_dashboard
DB_CONNECT_TIMEOUT=5

# Development-only one-time Admin bootstrap. Existing accounts are never reset.
# Authentication always uses the hashed password stored in the database.
AUTO_CREATE_ADMIN=true
LAKSHYA_BOOTSTRAP_ADMIN_USERNAME=admin
LAKSHYA_BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-strong-admin-password
